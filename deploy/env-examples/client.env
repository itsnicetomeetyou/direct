# =============================================================================
# DiReCT Client (Next.js Dashboard) - Production Environment Variables
# =============================================================================
# Copy this file to: client/.env.local
# Fill in all values before deploying.
# =============================================================================

# --- NextAuth ---
# Set NEXTAUTH_URL to your production domain
NEXTAUTH_URL=https://YOUR_DOMAIN.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here

# --- Email (Gmail SMTP) ---
APP_GMAIL_EMAIL=your-email@gmail.com
APP_GMAIL_PASS=your-gmail-app-password
APP_GMAIL_NAME=DiReCT

# --- GitHub OAuth (Optional) ---
# Create at: https://github.com/settings/developers
# Callback URL: https://YOUR_DOMAIN.com/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# --- Google Maps ---
NEXT_PUBLIC_GOOGLEMAPAPIKEY=your-google-maps-api-key

# --- Database ---
# Use the same database as the server
DATABASE_URL=postgresql://direct_user:YOUR_PASSWORD@localhost:5432/direct_db

# --- LaLaMOVE API ---
LALAMOVE_API_KEY=your-lalamove-api-key
LALAMOVE_API_SECRET=your-lalamove-api-secret
LALAMOVE_ENV=production
