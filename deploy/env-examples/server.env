# =============================================================================
# DiReCT Server (NestJS) - Production Environment Variables
# =============================================================================
# Copy this file to: server/.env
# Fill in all values before deploying.
# =============================================================================

# --- Database ---
# Use the credentials from setup-vps.sh (saved in /root/.direct-db-credentials)
DATABASE_URL=postgresql://direct_user:YOUR_PASSWORD@localhost:5432/direct_db

# --- Server ---
PORT=3001
NODE_ENV=production

# --- CORS ---
# Set to your frontend domain (e.g., https://yourdomain.com)
CORS_ORIGIN=https://YOUR_DOMAIN.com

# --- Email (Gmail SMTP) ---
APP_GMAIL_EMAIL=your-email@gmail.com
APP_GMAIL_PASS=your-gmail-app-password
APP_GMAIL_NAME=DiReCT

# --- Cloudinary (Image Storage) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- LaLaMOVE API ---
LALAMOVE_API_KEY=your-lalamove-api-key
LALAMOVE_API_SECRET=your-lalamove-api-secret
LALAMOVE_ENV=production

# --- Xendit (Payment Gateway) ---
XENDIT_SECRET_KEY=your-xendit-secret-key
